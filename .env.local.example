# ─── Sanity (existing) ──────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=yo6o30pq
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-31
SANITY_API_WRITE_TOKEN=

# ─── Supabase (new — booking module) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — never NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (new) ───────────────────────────────────────
# Test keys: sk_test_... / pk_test_... — switch to sk_live_... / pk_live_... before launch.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (new) ───────────────────────────────────────
RESEND_API_KEY=
# Use onboarding@resend.dev for early dev; verified domain before launch.
RESEND_FROM_EMAIL=noreply@crownnailbeauty.co.nz

# ─── Admin (new) ────────────────────────────────────────
# Comma-separated emails allowed to access /admin.
ADMIN_ALLOWLIST_EMAILS=

# ─── Rate limiting (new — Upstash Redis) ────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron (new — Railway) ───────────────────────────────
# 32+ random bytes, e.g. `openssl rand -hex 32`.
# Shared between the Railway cron service and the Next.js web service.
CRON_SECRET=

# ─── Optional: Captcha (Cloudflare Turnstile) ───────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Optional: Twilio (SMS reminders 24h before appointment) ────
# Leave blank to disable SMS reminders entirely. The cron endpoint short-circuits
# without TWILIO_ACCOUNT_SID set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 sender (purchased Twilio NZ number, e.g. +64211234567)
TWILIO_FROM_NUMBER=
